# Tailscale 认证配置
# 复制为 .env，填入本地路径，.env 不进 git

# 是否启用 Tailscale 认证（默认 true；调试时可改为 false）
TAILSCALE_AUTH=true

# tailscale 可执行文件的绝对路径
# 留空则在系统 PATH 中寻找；若 PATH 里没有，请填写完整路径
# 例：TAILSCALE_BIN=/opt/homebrew/bin/tailscale
TAILSCALE_BIN=

# tailscaled 的 unix socket 路径
# 留空则由 tailscale 自行寻址；若连接失败请手动填写
# 例：TAILSCALE_SOCKET=/var/run/tailscale/tailscaled.sock
TAILSCALE_SOCKET=

# 允许访问的 Tailscale LoginName，逗号分隔
# 留空 = 允许所有 tailnet 成员（仍需通过 whois 验证）
# 例：TAILSCALE_ALLOWED_LOGINS=alice@example.com,bob@example.com
TAILSCALE_ALLOWED_LOGINS=

# 允许执行管理员操作的用户，逗号分隔
# 例：TAILSCALE_ADMIN_LOGINS=alice@example.com
TAILSCALE_ADMIN_LOGINS=

# 服务端口（默认 3000）
PORT=3000
